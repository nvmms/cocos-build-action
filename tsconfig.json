{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "moduleResolution": "node",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "declaration": false,

    "sourceMap": false,

    "outDir": "dist"
  },

  "include": ["src/**/*"]
}